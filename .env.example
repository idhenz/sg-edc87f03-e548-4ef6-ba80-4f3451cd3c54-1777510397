# Database Configuration (MySQL)
DB_HOST=your-mysql-host.com
DB_USER=your-mysql-username
DB_PASSWORD=your-mysql-password
DB_NAME=your-database-name
DB_PORT=3306

# Biznet GIO Object Storage (S3-Compatible)
BIZNETGIO_ACCESS_KEY=your-access-key
BIZNETGIO_SECRET_KEY=your-secret-key
BIZNETGIO_BUCKET_NAME=dokumen
BIZNETGIO_ENDPOINT=https://nos.wjv-1.neo.id
BIZNETGIO_REGION=wjv-1

# Node Environment
NODE_ENV=production